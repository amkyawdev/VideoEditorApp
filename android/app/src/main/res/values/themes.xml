<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base Theme - Material 3 Dark -->
    <style name="Theme.VideoEditorApp" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary Colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        
        <!-- Secondary Colors -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_variant</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        
        <!-- Background -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnBackground">@color/on_background</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>
        
        <!-- Error -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/on_error</item>
        
        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        
        <!-- Window -->
        <item name="android:windowBackground">@color/background</item>
        
        <!-- Ripple -->
        <item name="android:colorControlHighlight">@color/ripple_color</item>
    </style>
    
    <!-- Full Screen Theme for Export -->
    <style name="Theme.VideoEditorApp.FullScreen">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>
    
    <!-- Splash Theme -->
    <style name="Theme.VideoEditorApp.Splash" parent="Theme.VideoEditorApp">
        <item name="android:windowBackground">@drawable/splash_background</item>
    </style>
    
    <!-- Card Styles -->
    <style name="Widget.VideoEditor.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
    </style>
    
    <style name="Widget.VideoEditor.Card.Outlined" parent="Widget.Material3.CardView.Outlined">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
    </style>
    
    <!-- Button Styles -->
    <style name="Widget.VideoEditor.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>
    
    <style name="Widget.VideoEditor.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/primary</item>
        <item name="android:textColor">@color/primary</item>
        <item name="cornerRadius">12dp</item>
    </style>
    
    <style name="Widget.VideoEditor.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/primary</item>
    </style>
    
    <style name="Widget.VideoEditor.Button.Icon" parent="Widget.Material3.Button.IconButton">
        <item name="iconTint">@color/on_surface</item>
        <item name="backgroundTint">@color/surface_variant</item>
        <item name="shapeAppearance">@style/ShapeAppearance.VideoEditor.IconButton</item>
    </style>
    
    <!-- FAB Styles -->
    <style name="Widget.VideoEditor.FAB" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/primary</item>
        <item name="tint">@color/on_primary</item>
        <item name="shapeAppearance">@style/ShapeAppearance.VideoEditor.FAB</item>
    </style>
    
    <!-- Shape Appearances -->
    <style name="ShapeAppearance.VideoEditor.FAB" parent="ShapeAppearance.Material3.Corner.Full">
        <item name="cornerSize">16dp</item>
    </style>
    
    <style name="ShapeAppearance.VideoEditor.IconButton" parent="ShapeAppearance.Material3.Corner.Medium">
        <item name="cornerSize">12dp</item>
    </style>
    
    <style name="ShapeAppearance.VideoEditor.Card" parent="ShapeAppearance.Material3.Corner.Medium">
        <item name="cornerSize">16dp</item>
    </style>
    
    <!-- Text Styles -->
    <style name="TextAppearance.VideoEditor.Headline" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>
    
    <style name="TextAppearance.VideoEditor.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>
    
    <style name="TextAppearance.VideoEditor.Subtitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/text_secondary</item>
    </style>
    
    <style name="TextAppearance.VideoEditor.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.VideoEditor.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/text_secondary</item>
    </style>
    
    <!-- Bottom Sheet Style -->
    <style name="Widget.VideoEditor.BottomSheet" parent="Widget.Material3.BottomSheet">
        <item name="backgroundTint">@color/surface</item>
        <item name="shapeAppearance">@style/ShapeAppearance.VideoEditor.BottomSheet</item>
    </style>
    
    <style name="ShapeAppearance.VideoEditor.BottomSheet" parent="ShapeAppearance.Material3.Corner.ExtraLarge">
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>
    
    <!-- Dialog Style -->
    <style name="Theme.VideoEditor.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">@color/surface</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.VideoEditor.Dialog</item>
    </style>
    
    <style name="ShapeAppearance.VideoEditor.Dialog" parent="">
        <item name="cornerSize">24dp</item>
    </style>
    
    <!-- Slider Style -->
    <style name="Widget.VideoEditor.Slider" parent="Widget.Material3.Slider">
        <item name="thumbColor">@color/primary</item>
        <item name="trackColorActive">@color/primary</item>
        <item name="trackColorInactive">@color/surface_variant</item>
    </style>
    
    <!-- Tab Layout Style -->
    <style name="Widget.VideoEditor.TabLayout" parent="Widget.Material3.TabLayout">
        <item name="tabIndicatorColor">@color/primary</item>
        <item name="tabSelectedTextColor">@color/primary</item>
        <item name="tabTextColor">@color/text_secondary</item>
        <item name="tabRippleColor">@color/ripple_color</item>
        <item name="tabIndicatorFullWidth">false</item>
        <item name="tabMode">fixed</item>
        <item name="tabGravity">fill</item>
    </style>
    
    <!-- Chip Style -->
    <style name="Widget.VideoEditor.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/surface_variant</item>
        <item name="chipStrokeColor">@color/divider</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="checkedIconTint">@color/primary</item>
    </style>
</resources>