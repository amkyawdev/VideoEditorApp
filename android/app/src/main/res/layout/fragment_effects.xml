<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            android:text="@string/tab_effects"
            android:textAppearance="@style/TextAppearance.VideoEditor.Subtitle"
            android:textColor="@color/text_primary" />

        <!-- Effect Presets -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvEffectPresets"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        <!-- Adjustments Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:text="Adjustments"
            android:textAppearance="@style/TextAppearance.VideoEditor.Subtitle"
            android:textColor="@color/text_primary" />

        <!-- Brightness Slider -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="@dimen/spacing_xs">

            <TextView
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:text="@string/effect_brightness"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/sliderBrightness"
                style="@style/Widget.VideoEditor.Slider"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:value="50"
                android:valueFrom="0"
                android:valueTo="100" />

            <TextView
                android:id="@+id/tvBrightnessValue"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="50%"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Contrast Slider -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="@dimen/spacing_xs">

            <TextView
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:text="@string/effect_contrast"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/sliderContrast"
                style="@style/Widget.VideoEditor.Slider"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:value="50"
                android:valueFrom="0"
                android:valueTo="100" />

            <TextView
                android:id="@+id/tvContrastValue"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="50%"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Saturation Slider -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="@dimen/spacing_xs">

            <TextView
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:text="@string/effect_saturation"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/sliderSaturation"
                style="@style/Widget.VideoEditor.Slider"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:value="50"
                android:valueFrom="0"
                android:valueTo="100" />

            <TextView
                android:id="@+id/tvSaturationValue"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="50%"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Warmth Slider -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="@dimen/spacing_xs">

            <TextView
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:text="Warmth"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/sliderWarmth"
                style="@style/Widget.VideoEditor.Slider"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:value="50"
                android:valueFrom="0"
                android:valueTo="100" />

            <TextView
                android:id="@+id/tvWarmthValue"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="50%"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Transform Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:text="Transform"
            android:textAppearance="@style/TextAppearance.VideoEditor.Subtitle"
            android:textColor="@color/text_primary" />

        <!-- Speed Control -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="@dimen/spacing_xs">

            <TextView
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:text="Speed"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/sliderSpeed"
                style="@style/Widget.VideoEditor.Slider"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:value="1.0"
                android:valueFrom="0.25"
                android:valueTo="4.0"
                android:stepSize="0.25" />

            <TextView
                android:id="@+id/tvSpeedValue"
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="1.0x"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Rotation Control -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="@dimen/spacing_sm">

            <TextView
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:text="Rotation"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleRotation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRotate0"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0°" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRotate90"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="90°" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRotate180"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="180°" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRotate270"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="270°" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

        </LinearLayout>

        <!-- Flip Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="@dimen/spacing_sm">

            <TextView
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:text="Flip"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFlipHorizontal"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Horizontal" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFlipVertical"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_sm"
                android:text="Vertical" />

        </LinearLayout>

        <!-- Color Effects Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:text="Color Effects"
            android:textAppearance="@style/TextAppearance.VideoEditor.Subtitle"
            android:textColor="@color/text_primary" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvColorEffects"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/spacing_lg" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnApplyEffects"
            style="@style/Widget.VideoEditor.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Apply Effects" />

    </LinearLayout>

</ScrollView>