<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/spacing_xs"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="@dimen/corner_radius_lg"
    app:cardElevation="@dimen/card_elevation"
    app:rippleColor="@color/ripple_color">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Thumbnail -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/project_thumbnail_height">

            <ImageView
                android:id="@+id/ivThumbnail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_thumbnail_placeholder"
                android:scaleType="centerCrop"
                tools:src="@color/surface_variant" />

            <!-- Duration badge -->
            <TextView
                android:id="@+id/tvDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_margin="@dimen/spacing_xs"
                android:background="@color/overlay_dark"
                android:paddingHorizontal="@dimen/spacing_xs"
                android:paddingVertical="2dp"
                android:textColor="@color/text_primary"
                android:textSize="10sp"
                tools:text="02:30" />

            <!-- Video count indicator -->
            <ImageView
                android:id="@+id/ivVideoIndicator"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="top|end"
                android:layout_margin="@dimen/spacing_xs"
                android:background="@color/overlay_dark"
                android:padding="2dp"
                android:src="@drawable/ic_video"
                android:visibility="gone"
                app:tint="@color/text_primary" />

        </FrameLayout>

        <!-- Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_sm">

            <TextView
                android:id="@+id/tvProjectName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textAppearance="@style/TextAppearance.VideoEditor.Body"
                android:textColor="@color/text_primary"
                tools:text="My Project" />

            <TextView
                android:id="@+id/tvProjectDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.VideoEditor.Caption"
                android:textColor="@color/text_secondary"
                tools:text="2 hours ago" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>